# Supabase — намери на https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Analytics — намери на https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity — намери на https://clarity.microsoft.com → Settings
NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx

# Site URL — твоят Vercel домейн (без trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
